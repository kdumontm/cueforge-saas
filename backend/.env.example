# FastAPI & Security Settings
# Generate a secure random string for SECRET_KEY (use: openssl rand -hex 32)
SECRET_KEY=your-secret-key-here

# Authentication algorithm
ALGORITHM=HS256

# JWT token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database Configuration
# For SQLite: sqlite:///./cueforge.db
# For PostgreSQL: postgresql://user:password@localhost/cueforge
# For MySQL: mysql+pymysql://user:password@localhost/cueforge
DATABASE_URL=sqlite:///./cueforge.db

# File Storage Configuration
# Options: local, s3
STORAGE_BACKEND=local

# Local storage paths
UPLOAD_DIR=uploads
EXPORT_DIR=exports

# AWS S3 Configuration (required if STORAGE_BACKEND=s3)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Stripe Payment Configuration (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Rate Limiting
# Maximum tracks that can be uploaded per day for Free plan
FREE_TRACKS_PER_DAY=5

# Maximum cue points for Free plan users
FREE_MAX_CUES=8

# Maximum cue points for Pro plan users
PRO_MAX_CUES=64

# CORS Configuration
# Use "*" for development, or comma-separated list of origins for production
# Example: http://localhost:3000,https://app.cueforge.com
CORS_ORIGINS=*
