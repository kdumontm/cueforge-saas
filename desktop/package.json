{
  "name": "cueforge",
  "version": "1.0.0",
  "description": "CueForge — L'app desktop pour les DJs. Analyse audio, cue points, et organisation musicale.",
  "main": "src/main.js",
  "author": {
    "name": "Kevin Dumont",
    "email": "kenin.dumont@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kdumontm/cueforge-saas"
  },
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg",
    "build:zip": "electron-builder --mac zip",
    "build:win": "electron-builder --win nsis zip",
    "build:all": "electron-builder --mac dmg zip --win nsis zip",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.cueforge.app",
    "productName": "CueForge",
    "afterPack": "./scripts/afterPack.js",
    "mac": {
      "category": "public.app-category.music",
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "darkModeSupport": true
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "zip",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CueForge"
    },
    "artifactName": "CueForge-${version}-${arch}.${ext}",
    "dmg": {
      "title": "CueForge-${arch}",
      "backgroundColor": "#0a0a0a",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "kdumontm",
      "repo": "cueforge-saas",
      "releaseType": "release"
    },
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  }
}
